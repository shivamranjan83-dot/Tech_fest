rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'email', 'userId', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /registrations/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidRegistration(request.resource.data);
      // Update and delete not permitted for simplicity of event logs, 
      // though one could allow name updates.
    }
  }
}
